<% content_for :title, "月次ふりかえり | Monthly Step" %>

<main class="reviews-page">
  <header class="reviews-header">
    <%= link_to "←", reviews_path, class: "reviews-back", "aria-label": "振り返り一覧に戻る" %>
    <h1 class="reviews-heading">月次ふりかえり</h1>
  </header>

  <%# 対象の月目標 %>
  <section class="reviews-card reviews-card--target">
    <p class="reviews-card-label">今月の目標</p>
    <p class="reviews-card-title"><%= @monthly_goal.title %></p>
    <p class="reviews-card-meta">
      <%= @monthly_goal.target_month.strftime("%Y年%-m月") %>
    </p>
  </section>

  <%# 達成率 %>
  <section class="reviews-card">
    <p class="reviews-card-label">達成率</p>
    <p class="reviews-show-rate"><%= @monthly_review.achievement_rate %><span class="reviews-show-rate-percent">%</span></p>
  </section>

  <%# 良かった点 %>
  <section class="reviews-card">
    <p class="reviews-card-label">今月の自分への一言</p>
    <p class="reviews-show-text"><%= simple_format(@monthly_review.good_point) %></p>
  </section>

  <%# 改善点 %>
  <section class="reviews-card">
    <p class="reviews-card-label">来月の自分への一言</p>
    <p class="reviews-show-text"><%= simple_format(@monthly_review.improvement_point) %></p>
  </section>

  <%# メモ %>
  <section class="reviews-card">
    <p class="reviews-card-label">メモ</p>
    <% if @monthly_review.memo.present? %>
      <p class="reviews-show-text"><%= simple_format(@monthly_review.memo) %></p>
    <% else %>
      <p class="reviews-show-text reviews-show-text--empty">メモはありません</p>
    <% end %>
  </section>

  <p class="reviews-back-link">
    <%= link_to "振り返り一覧へ戻る", reviews_path, class: "reviews-btn reviews-btn--secondary reviews-btn--full" %>
  </p>
</main>
