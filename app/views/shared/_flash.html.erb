<%#
  共通フラッシュメッセージ（issue29）
  - notice / success → 緑系（成功・お知らせ）
  - alert / error    → 赤系（エラー・警告）
  layouts/application.html.erb から常にレンダリングされる
%>
<% if flash.any? %>
  <div class="flash-stack" aria-live="polite">
    <% flash.each do |key, message| %>
      <% kind = %w[alert error].include?(key.to_s) ? "alert" : "notice" %>
      <div class="flash flash--<%= kind %>" role="<%= kind == "alert" ? "alert" : "status" %>">
        <span class="flash__icon" aria-hidden="true"><%= kind == "alert" ? "⚠" : "✓" %></span>
        <span class="flash__text"><%= message %></span>
      </div>
    <% end %>
  </div>
<% end %>
