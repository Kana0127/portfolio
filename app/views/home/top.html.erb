<% content_for :title, "Monthly Step" %>

<main class="top-page">
  <section class="top-card" aria-labelledby="top-heading">
    <p class="top-app-name">Monthly Step</p>

    <header class="top-header">
      <h1 id="top-heading" class="top-heading">はじめての方へ</h1>
      <p class="top-lead">小さな一歩を、一緒に始めましょう。</p>
    </header>

    <form class="top-form" action="#" method="post" data-turbo="false">
      <div class="top-form-group">
        <label class="top-label" for="top-email">メールアドレス</label>
        <input
          class="top-input"
          id="top-email"
          name="email"
          type="email"
          placeholder="your@email.com"
          autocomplete="email"
          disabled
        >
      </div>

      <div class="top-form-group">
        <label class="top-label" for="top-password">パスワード</label>
        <input
          class="top-input"
          id="top-password"
          name="password"
          type="password"
          placeholder="••••••••"
          autocomplete="new-password"
          disabled
        >
        <p class="top-form-hint">8文字以上の半角英数字</p>
      </div>

      <%= link_to "新規会員登録", new_user_path, class: "top-btn top-btn--primary", role: "button" %>
    </form>

    <div class="top-divider" role="separator" aria-label="または">
      <span class="top-divider-text">または</span>
    </div>

    <div class="top-oauth">
      <%= link_to "#", class: "top-btn top-btn--oauth top-btn--google", role: "button" do %>
        <span class="top-btn-icon" aria-hidden="true">G</span>
        <span class="top-btn-label">Googleで登録</span>
      <% end %>

      <%= link_to "#", class: "top-btn top-btn--oauth top-btn--apple", role: "button" do %>
        <span class="top-btn-icon" aria-hidden="true"></span>
        <span class="top-btn-label">Appleで登録</span>
      <% end %>
    </div>

    <p class="top-login-link">
      すでにアカウントをお持ちの方は<%= link_to "こちら", "#", class: "top-login-link-anchor" %>
    </p>
  </section>
</main>
