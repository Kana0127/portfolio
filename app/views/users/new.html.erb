<% content_for :title, "新規会員登録 | Monthly Step" %>

<main class="signup-page">
  <section class="signup-card" aria-labelledby="signup-heading">
    <p class="signup-app-name">Monthly Step</p>

    <header class="signup-header">
      <h1 id="signup-heading" class="signup-heading">新規会員登録</h1>
      <p class="signup-lead">アカウントを作成して、はじめの一歩を踏み出しましょう。</p>
    </header>

    <% if @user.errors.any? %>
      <div class="signup-error" role="alert">
        <p class="signup-error-title"><%= @user.errors.count %>件のエラーがあります</p>
        <ul class="signup-error-list">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, local: true, class: "signup-form" do |f| %>
      <div class="signup-form-group">
        <%= f.label :name, "ユーザー名", class: "signup-label" %>
        <%= f.text_field :name,
              class: "signup-input",
              placeholder: "まんすりい　たろう",
              autocomplete: "name" %>
      </div>

      <div class="signup-form-group">
        <%= f.label :email, "メールアドレス", class: "signup-label" %>
        <%= f.email_field :email,
              class: "signup-input",
              placeholder: "your@email.com",
              autocomplete: "email" %>
      </div>

      <div class="signup-form-group">
        <%= f.label :password, "パスワード", class: "signup-label" %>
        <%= f.password_field :password,
              class: "signup-input",
              placeholder: "••••••••",
              autocomplete: "new-password" %>
        <p class="signup-form-hint">3文字以上</p>
      </div>

      <div class="signup-form-group">
        <%= f.label :password_confirmation, "パスワード（確認用）", class: "signup-label" %>
        <%= f.password_field :password_confirmation,
              class: "signup-input",
              placeholder: "••••••••",
              autocomplete: "new-password" %>
      </div>

      <%= f.submit "登録する", class: "signup-btn signup-btn--primary" %>
    <% end %>

    <p class="signup-back-link">
      <%= link_to "TOPに戻る", root_path, class: "signup-back-link-anchor" %>
    </p>
  </section>
</main>
