<%#
  ロードマップ目標フォーム（new / edit 共通）
  ローカル変数:
    roadmap_goal : 対象の RoadmapGoal（新規 or 既存）
    categories   : カテゴリ選択肢
    submit_label : 送信ボタンの文言（"保存する" / "更新する"）
  form_with は model: roadmap_goal により new→POST、永続化済み→PATCH を自動判定する
%>
<% if roadmap_goal.errors.any? %>
  <div class="goal-new-error" role="alert">
    <p class="goal-new-error-title"><%= roadmap_goal.errors.count %>件のエラーがあります</p>
    <ul class="goal-new-error-list">
      <% roadmap_goal.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: roadmap_goal, local: true, class: "goal-new-form" do |f| %>
  <div class="goal-new-form-group">
    <%= f.label :title, "ロードマップ目標名", class: "goal-new-form-label" %>
    <%= f.text_field :title,
          class: "goal-new-form-input",
          placeholder: "例：ITエンジニアとしてのスキルアップ" %>
  </div>

  <div class="goal-new-form-group">
    <%= f.label :reason, "理由・目的（任意）", class: "goal-new-form-label" %>
    <%= f.text_area :reason,
          class: "goal-new-form-input goal-new-form-textarea",
          rows: 3,
          placeholder: "なぜこの目標を達成したいですか？" %>
  </div>

  <div class="roadmap-form-row">
    <div class="goal-new-form-group">
      <%= f.label :start_month, "開始月", class: "goal-new-form-label" %>
      <%= f.month_field :start_month,
            value: roadmap_goal.start_month&.strftime("%Y-%m"),
            class: "goal-new-form-input" %>
    </div>

    <div class="goal-new-form-group">
      <%= f.label :target_month, "目標達成月", class: "goal-new-form-label" %>
      <%= f.month_field :target_month,
            value: roadmap_goal.target_month&.strftime("%Y-%m"),
            class: "goal-new-form-input" %>
    </div>
  </div>

  <div class="goal-new-form-group">
    <span class="goal-new-form-label">目標カテゴリ</span>
    <div class="goal-new-chips" role="radiogroup" aria-label="目標カテゴリ">
      <% categories.each do |category| %>
        <label class="goal-new-chip">
          <%= f.radio_button :category_id, category.id, class: "goal-new-chip-input" %>
          <span class="goal-new-chip-label"><%= category.name %></span>
        </label>
      <% end %>
    </div>
  </div>

  <div class="goal-new-form-group">
    <%= f.label :status, "ステータス", class: "goal-new-form-label" %>
    <%= f.select :status,
          RoadmapGoal.status_options,
          {},
          class: "goal-new-form-input goal-new-form-select" %>
  </div>

  <%= f.submit submit_label, class: "goal-new-submit" %>
<% end %>
