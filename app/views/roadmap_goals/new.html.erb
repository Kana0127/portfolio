<% content_for :title, "ロードマップ目標を作る | Monthly Step" %>

<main class="goal-new-page">
  <header class="goal-new-header">
    <%= link_to "←", monthly_goals_path, class: "goal-new-back", "aria-label": "目標一覧に戻る" %>
    <h1 class="goal-new-heading">ロードマップ目標を作る</h1>
  </header>

  <section class="goal-new-card" aria-labelledby="roadmap-new-about">
    <div class="roadmap-note" id="roadmap-new-about">
      <p class="roadmap-note-title">ロードマップ目標とは？</p>
      <p class="roadmap-note-text">
        2か月以上かかる大きな目標です。月目標を束ねて長期的な進捗を管理できます。
        任意機能なので、なくても問題ありません。
      </p>
    </div>

    <%= render "form",
          roadmap_goal: @roadmap_goal,
          categories: @categories,
          submit_label: "保存する" %>
  </section>
</main>
