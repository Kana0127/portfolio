<% content_for :title, "月目標一覧 | Monthly Step" %>

<main class="goals-page">
  <header class="goals-page-header">
    <h1 class="goals-page-heading">月目標一覧</h1>
    <p class="goals-page-lead">今月・来月の目標を作って、小さな一歩を積み重ねましょう。</p>
  </header>

  <%# ＋ 新規目標作成 ＆ ボトムシート（ロードマップ/今月/今週 の選択） %>
  <div class="goals-create" data-controller="bottom-sheet">
    <button type="button"
            class="goals-btn goals-btn--primary goals-create-trigger"
            data-action="bottom-sheet#open">
      ＋ 新規目標作成
    </button>

    <div class="bottom-sheet"
         data-bottom-sheet-target="sheet"
         data-action="click->bottom-sheet#closeFromOverlay">
      <div class="bottom-sheet-panel" role="dialog" aria-modal="true" aria-label="作成する目標の種類を選ぶ">
        <span class="bottom-sheet-handle" aria-hidden="true"></span>
        <h2 class="bottom-sheet-title">何を作りますか？</h2>

        <%= link_to new_roadmap_goal_path, class: "bottom-sheet-option bottom-sheet-option--roadmap" do %>
          <span class="bottom-sheet-option-icon" aria-hidden="true">📖</span>
          <span class="bottom-sheet-option-body">
            <span class="bottom-sheet-option-title">ロードマップ目標を作る</span>
            <span class="bottom-sheet-option-desc">2か月以上の大きな目標</span>
          </span>
          <span class="bottom-sheet-option-arrow" aria-hidden="true">→</span>
        <% end %>

        <%= link_to new_monthly_goal_path(target_month: "this"), class: "bottom-sheet-option" do %>
          <span class="bottom-sheet-option-icon" aria-hidden="true">📅</span>
          <span class="bottom-sheet-option-body">
            <span class="bottom-sheet-option-title">今月の目標を作る</span>
            <span class="bottom-sheet-option-desc">ひと月で完結する目標</span>
          </span>
          <span class="bottom-sheet-option-arrow" aria-hidden="true">→</span>
        <% end %>

        <%# 今週の目標は月目標配下に作るため、月目標一覧セクションへ誘導する %>
        <a href="#goals-list" class="bottom-sheet-option" data-action="bottom-sheet#close">
          <span class="bottom-sheet-option-icon" aria-hidden="true">📝</span>
          <span class="bottom-sheet-option-body">
            <span class="bottom-sheet-option-title">今週の目標を作る</span>
            <span class="bottom-sheet-option-desc">月目標の中から週目標を追加できます</span>
          </span>
          <span class="bottom-sheet-option-arrow" aria-hidden="true">→</span>
        </a>

        <button type="button" class="bottom-sheet-cancel" data-action="bottom-sheet#close">
          キャンセル
        </button>
      </div>
    </div>
  </div>

  <%# ロードマップ目標（本人ぶん）。任意機能なので登録があるときだけ表示 %>
  <% if @roadmap_goals.present? %>
    <section class="roadmap-summary" aria-label="ロードマップ目標">
      <% @roadmap_goals.each do |roadmap| %>
        <article class="roadmap-summary-card">
          <div class="roadmap-summary-head">
            <span class="roadmap-summary-label">
              <span class="roadmap-summary-icon" aria-hidden="true">📖</span>
              ロードマップ目標
            </span>
            <span class="roadmap-summary-badge">任意</span>
          </div>
          <p class="roadmap-summary-title"><%= roadmap.title %></p>
          <p class="roadmap-summary-meta">
            <%= roadmap.start_month.strftime("%Y年%-m月") %> 〜 <%= roadmap.target_month.strftime("%Y年%-m月") %>
          </p>
          <%= link_to "ロードマップを見る →", roadmap_goal_path(roadmap), class: "roadmap-summary-link" %>
        </article>
      <% end %>
    </section>
  <% end %>

  <%# 来月：25日以降のみ表示。登録済みなら追加ボタンだけ出す %>
  <% if @next_month_available %>
    <% if @show_next_month_prompt %>
      <section class="goals-prompt goals-prompt--secondary" aria-label="来月の目標登録のお願い">
        <p class="goals-prompt-text">来月の目標を登録しましょう</p>
        <%= link_to "来月の目標を登録する", new_monthly_goal_path(target_month: "next"), class: "goals-btn goals-btn--secondary" %>
      </section>
    <% else %>
      <div class="goals-actions">
        <%= link_to "来月の目標を登録する", new_monthly_goal_path(target_month: "next"), class: "goals-btn goals-btn--secondary" %>
      </div>
    <% end %>
  <% end %>

  <section class="goals-list" id="goals-list">
    <% if @monthly_goals.empty? %>
      <p class="goals-empty">まだ月目標がありません。<br>「＋ 新規目標作成」からはじめましょう。</p>
    <% else %>
      <% @monthly_goals.each do |goal| %>
        <article class="goals-card">
          <header class="goals-card-header">
            <p class="goals-card-month"><%= goal.target_month.strftime("%Y年%-m月") %></p>
            <div class="goals-card-actions">
              <%= link_to "編集", edit_monthly_goal_path(goal), class: "goals-card-action-btn", aria: { label: "#{goal.title}を編集" } %>
              <%= button_to "削除",
                    monthly_goal_path(goal),
                    method: :delete,
                    form: {
                      class: "goals-card-action-form",
                      data: { turbo_confirm: "「#{goal.title}」を削除しますか？" }
                    },
                    class: "goals-card-action-btn goals-card-action-btn--danger",
                    aria: { label: "#{goal.title}を削除" } %>
            </div>
          </header>

          <h2 class="goals-card-title"><%= goal.title %></h2>

          <div class="goals-card-meta">
            <span class="goals-card-chip goals-card-chip--category"><%= goal.category.name %></span>
            <span class="goals-card-chip goals-card-chip--kind">
              <%= goal.step? ? "週分解型" : "単発型" %>
            </span>
          </div>

          <%# 週目標表示エリア（実データ）。並びは week_number 昇順、start_date 昇順 %>
          <section class="weekly-goals" aria-label="週目標">
            <h3 class="weekly-goals-heading">週目標</h3>

            <% sorted_weekly_goals = goal.weekly_goals.to_a.sort_by { |w| [w.week_number, w.start_date] } %>
            <% is_current_month_card = goal.target_month == @current_month_date %>
            <% if sorted_weekly_goals.empty? %>
              <p class="weekly-goals-empty">週目標はまだありません。</p>
            <% else %>
              <ol class="weekly-goals-list">
                <% sorted_weekly_goals.each do |wg| %>
                  <% is_current_week = is_current_month_card && wg.week_number == @current_week_number %>
                  <li class="weekly-goal-item <%= 'weekly-goal-item--current' if is_current_week %>"
                      <%= 'aria-current="true"'.html_safe if is_current_week %>>
                    <span class="weekly-goal-week">
                      <span class="weekly-goal-week-label">Week</span>
                      <span class="weekly-goal-week-number"><%= wg.week_number %></span>
                    </span>
                    <div class="weekly-goal-body">
                      <span class="weekly-goal-title"><%= wg.title %></span>
                      <span class="weekly-goal-date"><%= wg.start_date.strftime("%-m/%-d") %>〜</span>
                    </div>
                    <div class="weekly-goal-actions">
                      <%= link_to "編集",
                            edit_monthly_goal_weekly_goal_path(goal, wg),
                            class: "weekly-goal-action-btn",
                            aria: { label: "第#{wg.week_number}週「#{wg.title}」を編集" } %>
                      <%= button_to "削除",
                            monthly_goal_weekly_goal_path(goal, wg),
                            method: :delete,
                            form: {
                              class: "weekly-goal-action-form",
                              data: { turbo_confirm: "第#{wg.week_number}週「#{wg.title}」を削除しますか？" }
                            },
                            class: "weekly-goal-action-btn weekly-goal-action-btn--danger",
                            aria: { label: "第#{wg.week_number}週「#{wg.title}」を削除" } %>
                    </div>
                  </li>
                <% end %>
              </ol>
            <% end %>

            <%# 来月の月目標、かつ25日以前は週目標追加ボタンを出さない（Controller 側でも同じ判定を実施） %>
            <% is_next_month_card = goal.target_month == Date.current.next_month.beginning_of_month %>
            <% can_add_weekly_goal = !is_next_month_card || @next_month_available %>
            <% if can_add_weekly_goal %>
              <%= link_to "＋ 週目標を追加する",
                    new_monthly_goal_weekly_goal_path(goal),
                    class: "weekly-goals-add-btn" %>
            <% end %>
          </section>
        </article>
      <% end %>
    <% end %>
  </section>
</main>
